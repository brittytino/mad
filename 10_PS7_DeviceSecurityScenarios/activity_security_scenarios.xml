<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/etOtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="OTP will autofill here"
            android:inputType="number" />

        <Button
            android:id="@+id/btnStartOtpListen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start OTP Listener"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnInternetSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Internet On or Off Settings"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnUsbDebuggingSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="USB Debugging Settings"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnKeyboardSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Untrusted Keyboard Settings"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnLocationSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location On or Off Settings"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>
